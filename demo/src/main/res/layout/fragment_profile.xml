<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".ui.profile.ProfileFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="@dimen/spacing_xxl">

        <!-- ===== App 信息头部 ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="@dimen/profile_header_padding_top"
            android:paddingBottom="@dimen/profile_header_padding_bottom">

            <com.google.android.material.imageview.ShapeableImageView
                android:layout_width="@dimen/profile_avatar_size"
                android:layout_height="@dimen/profile_avatar_size"
                android:scaleType="centerCrop"
                android:src="@mipmap/ic_launcher"
                app:shapeAppearanceOverlay="@style/CircleImageView" />

            <TextView
                style="@style/Widget.PanoramaView.Text.Headline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/profile_title_margin_top"
                android:text="@string/app_name" />

            <TextView
                android:id="@+id/tv_user_status"
                style="@style/Widget.PanoramaView.Text.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/profile_subtitle_margin_top"
                tools:text="未登录" />
        </LinearLayout>

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/profile_divider_height"
            android:layout_marginHorizontal="@dimen/profile_section_padding_horizontal"
            android:background="?attr/colorOnSurface"
            android:alpha="0.08" />

        <!-- ===== 子项列表 ===== -->

        <!-- 登录/账号 项 -->
        <LinearLayout
            android:id="@+id/item_login"
            android:layout_width="match_parent"
            android:layout_height="@dimen/profile_list_item_height"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/profile_section_padding_horizontal">

            <ImageView
                android:id="@+id/ic_login"
                android:layout_width="@dimen/profile_icon_size"
                android:layout_height="@dimen/profile_icon_size"
                android:src="@drawable/ic_nav_profile"
                android:contentDescription="@string/go_login"
                app:tint="@color/primary" />

            <TextView
                android:id="@+id/tv_login_label"
                style="@style/Widget.PanoramaView.Text.Body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/profile_icon_margin_start"
                android:layout_weight="1"
                android:text="@string/go_login" />

            <TextView
                android:id="@+id/tv_login_hint"
                style="@style/Widget.PanoramaView.Text.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="未登录" />
        </LinearLayout>

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/profile_divider_height"
            android:layout_marginEnd="@dimen/profile_section_padding_horizontal"
            android:background="?attr/colorOnSurface"
            android:alpha="0.08" />

        <!-- 主题切换 项 -->
        <LinearLayout
            android:id="@+id/item_theme"
            android:layout_width="match_parent"
            android:layout_height="@dimen/profile_list_item_height"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/profile_section_padding_horizontal">

            <ImageView
                android:layout_width="@dimen/profile_icon_size"
                android:layout_height="@dimen/profile_icon_size"
                android:src="@drawable/ic_theme"
                android:contentDescription="@string/theme"
                app:tint="@color/primary" />

            <TextView
                style="@style/Widget.PanoramaView.Text.Body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/profile_icon_margin_start"
                android:layout_weight="1"
                android:text="@string/theme" />

            <TextView
                android:id="@+id/tv_theme_value"
                style="@style/Widget.PanoramaView.Text.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="跟随系统" />
        </LinearLayout>

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/profile_divider_height"
            android:layout_marginEnd="@dimen/profile_section_padding_horizontal"
            android:background="?attr/colorOnSurface"
            android:alpha="0.08" />

        <!-- 关于 项 -->
        <LinearLayout
            android:id="@+id/item_about"
            android:layout_width="match_parent"
            android:layout_height="@dimen/profile_list_item_height"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/profile_section_padding_horizontal">

            <ImageView
                android:layout_width="@dimen/profile_icon_size"
                android:layout_height="@dimen/profile_icon_size"
                android:src="@drawable/ic_about"
                android:contentDescription="@string/about"
                app:tint="@color/primary" />

            <TextView
                style="@style/Widget.PanoramaView.Text.Body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/profile_icon_margin_start"
                android:layout_weight="1"
                android:text="@string/about" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
